# ─── Google OAuth ────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a new project (or select existing)
# 3. Navigate to APIs & Services → Credentials
# 4. Click "Create Credentials" → "OAuth 2.0 Client IDs"
# 5. Application type: "Web application"
# 6. Authorized JavaScript origins:
#    - http://localhost:5173 (dev)
#    - http://localhost:8888 (Netlify dev)
#    - https://your-site.netlify.app (production)
# 7. Copy the Client ID below
GOOGLE_CLIENT_ID=your-google-client-id-here
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# ─── JWT Secret ──────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate-a-strong-random-string-here

# ─── Database (Neon Postgres via Netlify DB) ─────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Resend (Email) ─────────────────────────────────────
# 1. Sign up at https://resend.com
# 2. Verify a sending domain (or use onboarding@resend.dev for testing)
# 3. Create an API key
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=updates@ardeno.studio

# ─── Admin Access ────────────────────────────────────────
ADMIN_EMAILS=founder@ardeno.studio,suven@ardeno.studio

# ─── AI Assistant (Gemini) ───────────────────────────────
# 1. Go to https://aistudio.google.com/app/apikey
# 2. Create a new API key (free tier is sufficient)
GEMINI_API_KEY=your-gemini-api-key-here
